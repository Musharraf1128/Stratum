# ─── Stratum Environment Variables ──────────────────────────────────────────────

# API key for authenticating mutating routes (POST /run, POST /replay)
# Leave unset for dev mode (no auth required)
# STRATUM_API_KEY=your-secret-api-key

# Fernet key for encrypting API keys stored on runs
# Leave unset to auto-generate and store in .stratum_key file
# STRATUM_SECRET_KEY=your-fernet-base64-key

# SQLite database file path (default: stratum.db)
# STRATUM_DB_PATH=stratum.db

# Allowed CORS origin (default: http://localhost:5173)
# STRATUM_CORS_ORIGIN=http://localhost:5173
